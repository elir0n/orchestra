# ============================================================
# Orchestra — environment variables
# Copy this file to .env and fill in your values.
# ============================================================

# --- Anthropic (required by all agents that use Claude) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Operator notification email (where results are sent) ---
NOTIFY_EMAIL=you@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
# Gmail: create a 16-char App Password at https://myaccount.google.com/apppasswords
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# --- Optional global settings ---
LOG_LEVEL=INFO

# ============================================================
# referral-finder agent secrets
# Prefix: REFERRAL_FINDER_
# ============================================================

# Tavily web search API key (free tier: 1,000 searches/month)
# Get one at https://tavily.com
REFERRAL_FINDER_TAVILY_API_KEY=tvly-...

# GitHub personal access token (free, gives 5,000 req/hr for email lookup)
# Create one at https://github.com/settings/tokens (no scopes needed — public data only)
REFERRAL_FINDER_GITHUB_TOKEN=ghp_...

# Domain used in the SMTP EHLO greeting during email verification
# Any domain you own works fine; defaults to example.com if not set
REFERRAL_FINDER_SMTP_FROM_DOMAIN=yourdomain.com

# ============================================================
# job-finder agent secrets
# Prefix: JOB_FINDER_
# ============================================================

# Tavily web search API key (same key as referral-finder is fine)
# Get one at https://tavily.com
JOB_FINDER_TAVILY_API_KEY=tvly-...
